{
  "name": "@trip-flow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun --env-file=../../.env run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "bun --env-file=../../.env test",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@trip-flow/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.2.10",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@trip-flow/tsconfig": "workspace:*",
    "bun-types": "^1.1.42",
    "typescript": "^5.7.2"
  }
}
