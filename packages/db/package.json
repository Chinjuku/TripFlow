{
  "name": "@trip-flow/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "default": "./src/browser.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf .turbo dist",
    "db:generate": "bun --env-file ../../.env drizzle-kit generate",
    "db:push": "bun --env-file ../../.env drizzle-kit push",
    "db:studio": "bun --env-file ../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@trip-flow/tsconfig": "workspace:*",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  }
}
