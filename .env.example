# --- Shared ---
NODE_ENV=development

# --- apps/api (ElysiaJS) ---
PORT=4000

# Google OAuth 2.0 client (we handle sign-in ourselves, no Supabase Auth).
# Create at https://console.cloud.google.com/apis/credentials → "OAuth client ID"
# → Web application. Add GOOGLE_REDIRECT_URI below to "Authorized redirect URIs"
# and add the consent-screen scopes: openid, email, profile.
GOOGLE_CLIENT_ID=replace-with-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-with-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/callback

JWT_SECRET=replace-with-a-64-char-random-hex-string
WEB_URL=http://localhost:5173

# Any Postgres connection string. (A Supabase project's Postgres works fine —
# we use it only as a database now, not for auth.)
DATABASE_URL=postgres://user:password@host:6543/postgres

# Case use Supabase
SUPABASE_URL=https://exampledb.supabase.co

# Gemini API Key (Required for E-Slip Verification and Receipt OCR features)
# Create at https://aistudio.google.com/
GEMINI_API_KEY=replace-with-gemini-api-key

# --- apps/web (Vite) ---
# Vite only exposes VITE_-prefixed vars to the browser.
VITE_API_URL=http://localhost:4000

# Google Maps JavaScript API + Places API (New).
# Create at https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Places API (New).
# Restrict by HTTP referrer (localhost:5173, your prod domain) before shipping.
VITE_GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key
