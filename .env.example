# --- Shared ---
NODE_ENV=development

# --- apps/api (ElysiaJS) ---
PORT=4000
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
JWT_SECRET=replace-with-a-64-char-random-hex-string
WEB_URL=http://localhost:5173
DATABASE_URL=postgres://postgres.[project]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Gemini API Key (Required for E-Slip Verification and Receipt OCR features)
# Create at https://aistudio.google.com/
GEMINI_API_KEY=replace-with-gemini-api-key

# --- apps/web (Vite) ---
# Vite only exposes VITE_-prefixed vars to the browser.
VITE_API_URL=http://localhost:4000

# Google Maps JavaScript API + Places API (New).
# Create at https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Places API (New).
# Restrict by HTTP referrer (localhost:5173, your prod domain) before shipping.
VITE_GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key
